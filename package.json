{
  "name": "@anmotechno/medusa-plugin-wa-support",
  "version": "0.1.2",
  "description": "Whatsapp ticket and automation support for medusajs",
  "author": "ANMO",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Anas-mo101/medusa-plugin-wa-support"
  },
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-other",
    "medusa-plugin",
    "medusa-v2",
    "medusa-plugin-other"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "lint": "medusa lint",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@hapi/boom": "^10.0.1",
    "@medusajs/admin-sdk": "2.16.0",
    "@medusajs/admin-shared": "2.16.0",
    "@medusajs/cli": "2.16.0",
    "@medusajs/eslint-plugin": "2.16.0",
    "@medusajs/framework": "2.16.0",
    "@medusajs/icons": "2.16.0",
    "@medusajs/medusa": "2.16.0",
    "@medusajs/test-utils": "2.16.0",
    "@medusajs/ui": "4.1.16",
    "@swc/core": "^1.7.28",
    "@tanstack/react-query": "^5.101.1",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "eslint": "^9.0.0",
    "jiti": "^2.0.0",
    "prop-types": "^15.8.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.16.0",
    "@medusajs/admin-shared": "2.16.0",
    "@medusajs/cli": "2.16.0",
    "@medusajs/framework": "2.16.0",
    "@medusajs/icons": "2.16.0",
    "@medusajs/medusa": "2.16.0",
    "@medusajs/test-utils": "2.16.0",
    "@medusajs/ui": "4.1.16"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.2"
}
